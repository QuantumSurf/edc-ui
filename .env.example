# KMX EDC UI — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   # edit .env with your actual values
#   docker compose up -d

# ── PostgreSQL ────────────────────────────────────────────────────
# Password for the postgres service AND the app DATABASE_URL (keep in sync)
POSTGRES_PASSWORD=kmx_dev_123

# ── Application ───────────────────────────────────────────────────
# Full PostgreSQL connection string
# (when running via docker compose, use the service name "postgres" as host)
DATABASE_URL=postgresql://kmx:kmx_dev_123@postgres:5432/kmx_edc

# EDC Management API key sent as X-Api-Key header (leave empty if not required)
EDC_API_KEY=

# Legacy default EDC URL — no longer used for seeding, kept for reference
EDC_DEFAULT_URL=

# Set to "true" to disable demo login accounts (recommended for production)
VITE_DISABLE_DEMO=false

# ── 보안 (security) ───────────────────────────────────────────────
# JWT signing secret (운영 환경에서는 32자 이상의 random 값 필수). 미설정 시 dev에서는
# 프로세스 시작 시마다 ephemeral random secret 사용 → 재시작 시 모든 토큰 무효화.
JWT_SECRET=
JWT_EXPIRES_IN=12h

# 커넥터 EDC API Key at-rest 암호화 키(AES-256-GCM). 운영 필수 — 미설정 시 prod 에서는
# 커넥터 등록/수정이 거부된다(fail-closed). 안정적인(불변) random 값으로, 모든 레플리카가
# 동일 값을 공유해야 복호화가 일관된다. dev 미설정 시 고정 dev 키 사용.
HUB_APIKEY_SECRET=

# 로그인 무차별 대입 계정 잠금 — 연속 실패 임계/잠금 시간(분). 기본 10회/15분.
LOGIN_MAX_FAILURES=10
LOGIN_LOCKOUT_MINUTES=15

# 첫 부팅 시 자동 시드되는 데모 계정 비번. 미설정 시 random 비번을 stdout에 1회 출력.
# 운영에서는 8자 이상 + 흔한 약비번(password/12345678 등) 금지(거부됨).
SEED_ADMIN_PASSWORD=
SEED_OPERATOR_PASSWORD=
SEED_VIEWER_PASSWORD=

# DEV ONLY: catalog/negotiation/transfer dspEndpoint 검증에서 사설/loopback IP 허용.
# 운영에서는 false 또는 미설정 (SSRF 위험).
ALLOW_PRIVATE_DSP=false
