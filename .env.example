# KMX EDC UI — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   # edit .env with your actual values
#   docker compose up -d

# ── PostgreSQL ────────────────────────────────────────────────────
# App Postgres 비밀번호 (REQUIRED) — 프로덕션 compose 는 미설정 시 부팅을 거부한다.
# docker compose 는 이 값으로 앱의 DATABASE_URL 을 자동 구성한다.
POSTGRES_PASSWORD=

# ── Application ───────────────────────────────────────────────────
# Full PostgreSQL connection string — compose 외 직접 실행 시에만 사용
# (compose 실행 시에는 POSTGRES_PASSWORD 로부터 자동 구성되므로 비워도 됨)
DATABASE_URL=

# EDC Management API key sent as X-Api-Key header (leave empty if not required)
EDC_API_KEY=

# Legacy default EDC URL — no longer used for seeding, kept for reference
EDC_DEFAULT_URL=

# EDC QuerySpec 기본 limit — 미지정 시 EDC 는 목록을 50 으로 잘라 카운트/KPI/알림이 유실된다.
# 목록 절단 방지용 상한(기본 1000). 커넥터당 리소스가 매우 많으면 상향.
EDC_QUERY_LIMIT=1000

# Set to "true" to disable demo login accounts (recommended for production)
VITE_DISABLE_DEMO=false

# ── 보안 (security) ───────────────────────────────────────────────
# JWT signing secret (운영 환경에서는 32자 이상의 random 값 필수). 미설정 시 dev에서는
# 프로세스 시작 시마다 ephemeral random secret 사용 → 재시작 시 모든 토큰 무효화.
JWT_SECRET=
JWT_EXPIRES_IN=12h

# 커넥터 EDC API Key at-rest 암호화 키(AES-256-GCM). 운영 필수 — 미설정 시 prod 에서는
# 커넥터 등록/수정이 거부된다(fail-closed). 안정적인(불변) random 값으로, 모든 레플리카가
# 동일 값을 공유해야 복호화가 일관된다. dev 미설정 시 고정 dev 키 사용.
HUB_APIKEY_SECRET=

# 로그인 무차별 대입 계정 잠금 — 연속 실패 임계/잠금 시간(분). 기본 10회/15분.
LOGIN_MAX_FAILURES=10
LOGIN_LOCKOUT_MINUTES=15

# 첫 부팅 시 자동 시드되는 데모 계정 비번. 미설정 시 random 비번을 stdout에 1회 출력.
# 운영에서는 8자 이상 + 흔한 약비번(password/12345678 등) 금지(거부됨).
SEED_ADMIN_PASSWORD=
SEED_OPERATOR_PASSWORD=
SEED_VIEWER_PASSWORD=

# DEV ONLY: catalog/negotiation/transfer dspEndpoint 검증에서 사설/loopback IP 허용.
# 운영에서는 false 또는 미설정 (SSRF 위험).
ALLOW_PRIVATE_DSP=false

# ── Platform infrastructure (kmx-platform) ────────────────────────
# 프로덕션 compose 는 Vault 토큰/플랫폼 DB 를 미설정 시 부팅을 거부한다(REQUIRED).
# PLATFORM_VAULT_TOKEN 은 절대 'root' 금지. PLATFORM_DATABASE_URL 은 dev 기본값 금지.
PLATFORM_VAULT_URL=http://platform-vault:8200
PLATFORM_VAULT_TOKEN=
PLATFORM_VAULT_NAMESPACE=
PLATFORM_DATABASE_URL=

# Digital Twin Registry / IdentityHub baseline (UI can override per-tenant)
DTR_BASE_URL=http://platform-dtr:4243/semantics/registry
IDENTITY_HUB_URL=
IDENTITY_HUB_PARTICIPANT_ID=
IDENTITY_HUB_API_KEY=
